# Database — Supabase PostgreSQL
# DATABASE_URL: Transaction pooler (port 6543) — used by app at runtime
#   Username MUST be postgres.[project-ref] (not just postgres) for the pooler
#   Region in host varies — copy exact URL from Supabase → Connect → Transaction pooler
#   Append ?pgbouncer=true so Prisma skips prepared statements (required for pgBouncer)
# DIRECT_URL: Direct connection (port 5432) — only needed for prisma migrate deploy
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# Ingestion — RapidAPI key for "Realty US" by ntd119
# https://rapidapi.com/ntd119/api/realty-us
RAPIDAPI_KEY=
RAPIDAPI_HOST=realty-us.p.rapidapi.com

# Cloudflare R2 photo storage
# From: Cloudflare Dashboard > R2 > Manage API Tokens
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pricetag-photos
R2_PUBLIC_URL=https://photos.pricetag.app

# Auth — NextAuth (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Rate limiting — Upstash Redis (https://console.upstash.com, free tier)
# If unset, rate limiting is disabled (safe for local dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Set to "0" if you're NOT hosting on Vercel (or another platform that
# strips client-provided x-forwarded-for headers). With it disabled,
# all traffic shares a single rate-limit bucket — safer but coarser.
# Default ("1" or unset) trusts x-forwarded-for.
RATE_LIMIT_TRUST_FORWARDED=1

# Error tracking — Sentry (https://sentry.io, free tier)
# SENTRY_DSN and NEXT_PUBLIC_SENTRY_DSN take the same value (DSNs are safe to be public)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=        # org slug — only needed for CI source map uploads
SENTRY_PROJECT=    # project slug — only needed for CI source map uploads

# Neighborhood map — variant B (Google Maps) is off by default.
# Set NEXT_PUBLIC_DAILY_MAP_PROVIDER=google to flip the global flag.
# Restrict the API key by HTTP referrer to your domain(s) — see
# design_handoff_pricetag/GOOGLE_MAPS_INTEGRATION.md §1.1.
NEXT_PUBLIC_DAILY_MAP_PROVIDER=illustrated
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_ID=     # optional — Cloud-based Map ID for the paper-palette style
