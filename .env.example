# Database (SQLite for dev, switch to postgresql for production)
DATABASE_URL="file:./dev.db"

# Ingestion — RapidAPI key for Realtor.com data
RAPIDAPI_KEY=
RAPIDAPI_HOST="realtor.p.rapidapi.com"

# Cloudflare R2 photo storage
# Get from: Cloudflare Dashboard > R2 > API Tokens
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pricetag-photos
R2_PUBLIC_URL=https://photos.pricetag.app
