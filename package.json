{
  "name": "pricetag",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "db:setup": "prisma migrate dev --name init",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "ingest:full": "tsx scripts/ingest.ts",
    "ingest:plan": "tsx scripts/ingest-plan.ts",
    "ingest:fetch": "tsx scripts/ingest-stage.ts fetch",
    "ingest:normalize": "tsx scripts/ingest-stage.ts normalize",
    "ingest:mirror": "tsx scripts/ingest-stage.ts mirror",
    "ingest:persist": "tsx scripts/ingest-stage.ts persist",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.52.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vis.gl/react-google-maps": "^1.8.3",
    "bcryptjs": "^3.0.3",
    "eslint-config-next": "^16.2.6",
    "framer-motion": "^11.18.2",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.31",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "p-throttle": "^8.1.0",
    "postcss": "^8.5.10",
    "prisma": "^5.22.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  }
}
