// Prisma schema for Pricetag
// Swap `provider = "sqlite"` for `"postgresql"` in production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
}

model Listing {
  id              String   @id @default(cuid())
  externalId      String?  @unique // ID from source API (e.g. Realtor.com property_id)
  source          String   // "realtor" | "zillow" | "manual" | "seed"

  // Address (we display neighborhood + city + state, NOT street until reveal)
  streetAddress   String
  neighborhood    String?
  city            String
  state           String   // 2-letter
  zipCode         String?
  latitude        Float?
  longitude       Float?

  // Facts
  beds            Int
  baths           Float    // half-baths exist
  sqft            Int?
  lotSqft         Int?
  yearBuilt       Int?
  homeType        String?  // "single_family" | "condo" | "townhouse" | etc.

  // The answer
  soldPrice       Int      // in dollars, the truth
  soldDate        DateTime?
  isSold          Boolean  @default(true)

  // Quality control
  isActive        Boolean  @default(true)
  qualityScore    Int      @default(50) // 0-100, used to filter low-quality listings
  lastShownAt     DateTime? // for rotation freshness

  // Photos
  photos          Photo[]

  // Ingestion metadata
  ingestedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Game references
  rounds          Round[]
  savedBy         SavedHome[]

  @@index([isActive, qualityScore])
  @@index([state, city])
  @@index([soldPrice])
}

model Photo {
  id           String   @id @default(cuid())
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId    String
  url          String   // mirrored 1600w URL (or original if not mirrored yet)
  thumbnailUrl String?  // mirrored 400w URL
  sourceUrl    String?  // original 3rd-party URL (kept for debugging)
  width        Int?
  height       Int?
  ordering     Int      @default(0)
  caption      String?

  @@index([listingId, ordering])
}

model Game {
  id              String    @id @default(cuid())
  sessionId       String
  userId          String?
  gameType        String    @default("freeplay")
  totalRounds     Int       @default(5)
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  totalScore      Int?

  // Denormalized aggregates populated at completion. Cheaper than re-joining
  // Round + Listing for profile/leaderboard reads. Nullable so the column
  // can land before the write path ships and for in-progress games.
  avgAccuracy     Float?
  avgErrorPct     Float?
  bestRoundScore  Int?
  worstRoundScore Int?
  bestRoundAcc    Float?
  durationMs      Int?

  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  rounds          Round[]

  @@index([sessionId])
  @@index([userId, completedAt])
  @@index([totalScore])
  @@index([userId, avgAccuracy])
}

model Round {
  id          String   @id @default(cuid())
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameId      String
  listing     Listing  @relation(fields: [listingId], references: [id])
  listingId   String

  roundNumber Int
  guess       Int?
  score       Int?
  // 0..1 accuracy snapshot, clamped from 1 - |guess - soldPrice| / soldPrice.
  // Materialised at score time so aggregates don't have to recompute and join.
  accuracy    Float?
  guessedAt   DateTime?

  // Denormalized from Listing at score time. Lets analytics group by market
  // without joining Listing — useful for "which markets are your best?" reports.
  listingCity  String?
  listingState String?

  @@unique([gameId, roundNumber])
  @@index([gameId, roundNumber])
  // Covering index for the landing "last 24h" aggregate.
  @@index([guessedAt])
  @@index([listingState, listingCity])
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String?   @unique
  passwordHash String
  createdAt    DateTime  @default(now())

  games         Game[]
  dailyProgress UserDailyProgress?
  savedHomes    SavedHome[]
}

// NOTE: NextAuth v5 + Credentials provider + JWT session strategy does NOT use
// the Account / Session / VerificationToken tables — those are for the OAuth
// adapter pattern. If you add an OAuth provider (Google, GitHub, etc.) later,
// you'll need to bring them back. The dropped tables in earlier migrations
// were intentional.

model UserDailyProgress {
  userId           String   @id
  lastPlayedDateET String?
  lastResult       Json?
  currentStreak    Int      @default(0)
  bestStreak       Int      @default(0)
  played           Int      @default(0)
  history          Json     @default("[]")
  distribution     Json     @default("{\"90+\":0,\"80\":0,\"70\":0,\"60\":0,\"50\":0,\"<50\":0}")
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IngestionRun {
  id               String    @id @default(cuid())
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  status           String    // "running" | "success" | "failed"
  marketsRequested Int       @default(0)
  listingsFound    Int       @default(0)
  listingsIngested Int       @default(0)
  listingsSkipped  Int       @default(0)
  errorLog         String?   // truncated error details
}

model SavedHome {
  id          String   @id @default(cuid())
  userId      String
  listingId   String

  // Score snapshot — populated post-reveal. All null on a pre-reveal save.
  guess       Int?
  actualPrice Int?
  accuracy    Float?
  tier        String?

  savedAt     DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId, savedAt])
}
